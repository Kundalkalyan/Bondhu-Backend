# GEMINI_API_KEY: Required for Gemini AI API calls.
# The server environment automatically injects this at runtime from secrets.
# Users configure this via the Secrets/Environment panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# The hosting environment automatically injects this at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
